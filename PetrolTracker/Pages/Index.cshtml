@page
@model PetrolTracker.Pages.IndexModel

<meta charset="UTF-8">
<link href="https://cdn.jsdelivr.net/npm/nouislider@15.7.1/dist/nouislider.min.css" rel="stylesheet">
<link href="/css/style.css" rel="stylesheet" type="text/css" />

<div class="grid-container">

    <!-- Левая часть: карта -->
    <div id="map"></div>

    <!-- Правая часть: фильтры + список -->
    <div class="side-panel">
        <div class="row-direction-container">
            <button class="open-filter-button">Фильтры</button>
        </div>
        <!-- Карточка фильтров -->
        <div class="modal-overlay">
            <div class="filter-card">
                <h3>⚙️ Фильтры</h3>

                <div class="form-group">
                    <label>Название АЗС</label>
                    <input type="text" id="filter-name" class="form-control" placeholder="Например: Лукойл" />
                </div>
                <div class="form-group">
                    <label>Адрес</label>
                    <input type="text" id="filter-address" class="form-control" placeholder="Например: ул Ленина" />
                </div>

                <div class="form-group">
                    <label>Вид топлива</label>
                    <div id="filter-fuel" class="form-control row-direction-container">
                        @{
                            foreach(DbManager.Petrol petrol in Model.Petrols!){
                                <button class="allow-fuels" data-fuel="@petrol.Name.ToLower()" data-price="@petrol.Price">
                                    <span class="fuel-name">@petrol.Name</span>
                                </button>
                            }
                        }
                    </div>
                </div>

                <div class="form-group">
                    <label>Цена, ₽</label>
                    <div class="row-direction-container">
                        <span id="minVal">@Model.PriceRange.min</span>
                        <div id="slider"></div>
                        <span id="maxVal">@Model.PriceRange.max</span>
                    </div>
                </div>
                <div class="form-group">
                    <label>Рэйтинг АЗС</label>
                    <div class="row-direction-container">
                        <span id="minValRatingStation">0</span>
                        <div id="slider-station" class="slider"></div>
                        <span id="maxValRatingStation">5</span>
                    </div>
                </div>
                <div class="form-group">
                    <label>Рэйтинг топлива</label>
                    <div class="row-direction-container">
                        <span id="minValRatingPetrol">0</span>
                        <div id="slider-petrol" class="slider"></div>
                        <span id="maxValRatingPetrol">5</span>
                    </div>
                </div>

                <div class="filter-actions">
                    <button id="filter-submit" class="btn-primary">Применить</button>
                    <button id="filter-reset" class="btn-secondary">Сбросить</button>
                </div>
            </div>
        </div>

        <!-- Список заправок -->
        <div class="scroll_div" id="station-list">
            @foreach (DbManager.GasStation el in Model.GasStations!)
            {
                <div class="station-card GasStation"
                     data-name="@el.Name.ToLower()"
                     data-fuels="@string.Join(",", el.Petrols.Select(p => p.Name.ToLower()))">

                    <div class="station-name">@el.Name.ToUpper()</div>
                    <div class="station-address location">@el.Address</div>

                    <div class="fuels-list">
                        @foreach (var petrol in el.Petrols)
                        {
                            <div class="fuel-tag" data-fuel="@petrol.Name.ToLower()" data-price="@petrol.Price">
                                <span class="fuel-name">@petrol.Name</span>
                                <span class="fuel-price">@petrol.Price ₽</span>
                                <span class="fuel-date">@Model.GetUpdate(el, petrol)</span>
                                <div class="petrol-rating">
                                    @{
                                        var ratingPair = Model.GetPetrolRating(el, petrol);
                                        for(int i = 0; i < 5; ++i){
                                            if(ratingPair.rating >= i + 1){
                                                <span class="rating-star" style="color: #fbbf24;" data-value="@i + 1">★</span>
                                            }
                                            else{
                                                <span class="rating-star" data-value="@i">★</span>
                                            }
                                        }
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    <div class="row-direction-container">
                        <div class="station-rating">
                            @for(int i = 0; i < 5; ++i){
                                if(el.Rating >= i + 1){
                                    <span class="rating-star" style="color: #fbbf24;" data-value="@i + 1">★</span>
                                }
                                else{
                                    <span class="rating-star" data-value="@i">★</span>
                                }
                            }
                        </div>
                        <span id="rating-count">Оценок: @el.Stars</span>
                        <button id="station-page-button" onclick="window.location.href = window.location.origin + '/info' + '?id=@el.Id';"> Подробнее </button>
                    </div>
                </div>
            }
        </div>

    </div>
</div>

<script src="https://api-maps.yandex.ru/2.1/?apikey=107a0c84-45d3-407b-a236-9daa3692445c&load=package.full&lang=ru-RU" type="text/javascript"></script>
<script src="https://cdn.jsdelivr.net/npm/nouislider@15.7.1/dist/nouislider.min.js"></script>

<script src="/js/Index.js"></script>
