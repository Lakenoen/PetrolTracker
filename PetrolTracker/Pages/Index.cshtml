@page
@model PetrolTracker.Pages.IndexModel

<meta charset="UTF-8">
<link href="/css/style.css" rel="stylesheet" type="text/css" />

<div class="grid-container">
	<div id="map"></div>
	<div class="glass-div">
		<div class="filter-container">
			<button id="filter-submit">Submit</button>
		</div>
		<div class="scroll_div">
			@{
				foreach (DbManager.GasStation el in Model.GasStations!) 
				{
					<div class="glass-div GasStation">
						<div class="card-header">@el.Name.ToUpper()</div>
						<div class="card-body">
							<div class="minimal-box-column">
								<p class="location">@el.Address</p>
							</div>
								<div class="minimal-box-row">
								@{
									foreach(var petrol in el.Petrols)
									{
										<div>
											<p>@petrol.Name</p>
											<p>@petrol.Price</p>
											<p>@Model.GetUpdate(el, petrol)</p>
										</div>
									}
								}
							</div>
						</div>
					</div>
				}
			}
		</div>
	</div>
	<l>erge</l>
</div>

<script src="https://api-maps.yandex.ru/2.1/?apikey=107a0c84-45d3-407b-a236-9daa3692445c&load=package.full&lang=ru-RU" type="text/javascript"></script>

<script src="/js/Index.js"></script>
