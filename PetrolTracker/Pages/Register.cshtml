@page
@model PetrolTracker.Pages.RegisterModel
@{
    ViewData["Title"] = "Регистрация";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>Регистрация — PetrolTracker</title>
    <link href="/css/auth.css" rel="stylesheet" />
</head>
<body>
<div class="auth-container">
    <h2>Регистрация</h2>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-error">@Model.ErrorMessage</div>
    }

    <form method="post">
        <div class="form-group">
            <label>Email</label>
            <input asp-for="Input.Email" type="email" class="form-control" required />
        </div>
        <div class="form-group">
            <label>Логин</label>
            <input asp-for="Input.UserName" class="form-control" required />
        </div>
        <div class="form-group">
            <label>Пароль (минимум 6 символов)</label>
            <input asp-for="Input.Password" type="password" class="form-control" required minlength="6" />
        </div>
        <button type="submit" class="btn-primary">Зарегистрироваться</button>
        <a href="/Login">Уже есть аккаунт?</a>
    </form>
</div>
</body>
</html>
