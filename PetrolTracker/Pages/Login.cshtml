@page
@model PetrolTracker.Pages.LoginModel
@{
    ViewData["Title"] = "Вход";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>Вход — PetrolTracker</title>
    <link href="/css/auth.css" rel="stylesheet" />
</head>
<body>
<div class="auth-container">
    <h2>Вход в систему</h2>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-error">@Model.ErrorMessage</div>
    }

    <form method="post">
        <div class="form-group">
            <label>Email</label>
            <input asp-for="Input.Email" type="email" class="form-control" required />
        </div>
        <div class="form-group">
            <label>Пароль</label>
            <input asp-for="Input.Password" type="password" class="form-control" required />
        </div>
        <button type="submit" class="btn-primary">Войти</button>
        <a href="/Register">Нет аккаунта? Зарегистрироваться</a>
    </form>
</div>
</body>
</html>
